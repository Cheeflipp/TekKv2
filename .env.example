# Miljøvariabler for TekK
# Kopier denne fil til .env.local og udfyld værdierne

# Email Integration (Resend)
# Opret en gratis konto på resend.com og indsæt din API nøgle her
RESEND_API_KEY=
# Din email adresse, hvor du vil modtage notifikationer om nye bookinger
ADMIN_EMAIL=
# Afsender email (Når du har verificeret dit domæne hos Resend, f.eks. booking@dit-domæne.dk)
EMAIL_FROM=
